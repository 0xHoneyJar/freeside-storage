{
  "name": "@0xhoneyjar/freeside-storage-stickers",
  "version": "0.0.1",
  "description": "Sealed StickerProfile Effect Schema + service interface for the freeside-storage asset plane. Profile-scaffolds-all sticker resolution; client/server agnostic; composes with @0xhoneyjar/freeside-storage-client URL_CONTRACT_V1. Phase-0 Schema substrate per composable-sticker-substrate-2026-05-01 cycle.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/freeside-storage.git",
    "directory": "packages/stickers"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm test:node && pnpm test:jsdom",
    "test:node": "vitest run --config vitest.config.ts",
    "test:jsdom": "vitest run --config vitest.config.jsdom.ts",
    "test:watch": "vitest --config vitest.config.ts"
  },
  "dependencies": {
    "@0xhoneyjar/freeside-storage-client": "workspace:*",
    "@0xhoneyjar/freeside-storage-protocol": "workspace:*",
    "effect": "^3.10.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
